# ── Application Settings ─────────────────────────────────────────
APP_NAME=Business Listings Dashboard
APP_VERSION=1.0.0
DEBUG=True

# ── Database Configuration ───────────────────────────────────────
# Set USE_SQLITE=True for local development without MySQL
USE_SQLITE=True
SQLITE_URL=sqlite:///./business_listings.db

# MySQL settings (used when USE_SQLITE=False)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=business_listings

# ── CORS ─────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Scraper ──────────────────────────────────────────────────────
SCRAPER_MODE=mock
SCRAPER_LISTING_COUNT=500
SCRAPER_REQUEST_DELAY=1.0

# ── Server ───────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
